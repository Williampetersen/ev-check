# Database
DATABASE_URL=
POSTGRES_URL=
DATABASE_AUTO_SETUP=true
DATABASE_RUN_MIGRATIONS=false

# Admin access
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_PASSWORD_HASH=
ADMIN_SESSION_SECRET=

# Customer and agent sessions
CUSTOMER_SESSION_SECRET=
AGENT_SESSION_SECRET=
AGENT_PASSWORD=
COOKIE_SECURE=

# Optional private preview gate. Keep false/empty for SEO and public launch.
SITE_ACCESS_ENABLED=false
SITE_ACCESS_USERNAME=
SITE_ACCESS_PASSWORD=
SITE_ACCESS_SECRET=

# Mail / SMTP
SMTP_HOST=send.one.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=info@ev-check.dk
SMTP_PASSWORD=
MAIL_FROM="EV-Check.dk <info@ev-check.dk>"
MAIL_FROM_NAME=EV-Check.dk
BOOKING_ADMIN_EMAIL=info@ev-check.dk
# Unused: all customer/admin links and email images now always use the
# canonical https://evcheck.dk domain from lib/seo.ts, ignoring this var.
APP_URL=https://evcheck.dk

# Optional production hardening
DATABASE_MAX_CONNECTIONS=5
